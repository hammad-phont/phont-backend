PORT=5055

# Deployed Next app that exposes /api/subtitle-export/*
NEXT_EXPORT_BASE_URL=http://4.210.217.8/

# Source API for subtitle and metadata
SUBTITLE_SOURCE_API_BASE_URL=https://demo-api-dev.phont.ai
# Upload API for media ingestion
UPLOAD_API_BASE_URL=https://upload.demo-api-dev.phont.ai

# Optional source API key
SUBTITLE_SOURCE_X_API_KEY=
# Plugin/upload flow API key (defaults to SUBTITLE_SOURCE_X_API_KEY if omitted)
PLUGIN_X_API_KEY=

# Optional fixed bearer/session if you already have credentials
SUBTITLE_SOURCE_BEARER_TOKEN=
SUBTITLE_SOURCE_SESSION_ID=

# Auto-login credentials (used when source API returns 401)
# If not set, service also checks NEXT_PUBLIC_AUTO_LOGIN_USERNAME/PASSWORD.
SUBTITLE_SOURCE_AUTO_LOGIN_USERNAME=
SUBTITLE_SOURCE_AUTO_LOGIN_PASSWORD=

# Export defaults
EXPORT_WIDTH=1920
EXPORT_HEIGHT=1080
EXPORT_FPS=60
EXPORT_FORMAT=prores4444-mov

# Polling / timeout tuning
EXPORT_POLL_INTERVAL_MS=1200
EXPORT_POLL_TIMEOUT_MS=900000
HTTP_TIMEOUT_MS=30000
UPLOAD_TIMEOUT_MS=900000
PLUGIN_POLL_INTERVAL_MS=10000
PLUGIN_POLL_TIMEOUT_MS=3600000
UPLOAD_MAX_FILE_BYTES=524288000
