PORT=5055

# Running Next app that already has /api/subtitle-export endpoints
NEXT_EXPORT_BASE_URL=http://127.0.0.1:3000

# Source API for subtitle + vod metadata lookup
SUBTITLE_SOURCE_API_BASE_URL=https://demo-api-dev.phont.ai

# Optional auth for source API
# If your backend accepts x-api-key:
SUBTITLE_SOURCE_X_API_KEY=
# If your backend accepts bearer auth:
SUBTITLE_SOURCE_BEARER_TOKEN=

# Export defaults
EXPORT_WIDTH=1920
EXPORT_HEIGHT=1080
EXPORT_FPS=60
EXPORT_FORMAT=prores4444-mov

# Polling / timeout tuning
EXPORT_POLL_INTERVAL_MS=1200
EXPORT_POLL_TIMEOUT_MS=900000
HTTP_TIMEOUT_MS=30000
